const express = require("express");
const router = express.Router();
const OpenAI = require("openai");

function getOpenAI() {
  return new OpenAI({
    apiKey: process.env.OPENAI_API_KEY,
    baseURL: "https://openrouter.ai/api/v1",
  });
}

/** true = I committed; false = someone else committed to me */
function parseIsMine(value) {
  if (value === true || value === "true") return true;
  if (value === false || value === "false") return false;
  return false;
}

router.post("/", async (req, res) => {
  const { task, deadline, isMine: isMineRaw } = req.body;
  const isMine = parseIsMine(isMineRaw);

  if (task === undefined || task === null || String(task).trim() === "") {
    return res.status(400).json({ error: "task is required" });
  }

  const deadlineStr =
    deadline !== undefined && deadline !== null && !Number.isNaN(Number(deadline))
      ? new Date(Number(deadline)).toLocaleString()
      : "unspecified";

  const theirsInstructions = `
The recipient of YOUR email is the person who MADE this commitment (they promised to do it).
You did NOT miss this commitment yourself. Do NOT apologize as if you failed to do the task.
Write a short, polite follow-up (2–4 sentences) that:
- References the specific commitment below in plain language (use the exact topic, e.g. driving, a document, a meeting).
- Gently checks status or offers help if appropriate.
- Sounds natural, not accusatory.

Do NOT say you are sorry for missing the deadline or for not doing their task.
Do NOT use placeholders like [Name]. No fake names.
`;

  const mineInstructions = `
The person writing is the one who MADE this commitment and missed or is late on the deadline.
Write a short professional apology / recommit email (2–4 sentences): acknowledge the slip, restate the task briefly, propose next steps.
Do NOT use placeholders like [Name]. No fake names.
`;

  const prompt = `
${isMine ? mineInstructions : theirsInstructions}

Commitment (task summary): ${String(task).trim()}
Relevant deadline (context): ${deadlineStr}

Respond with ONLY valid JSON in this exact shape:
{"subject":"...","body":"..."}
subject = email subject line (no "Subject:" prefix).
body = email body only, plain text, use \\n for line breaks between paragraphs if needed.
`;

  try {
    const openai = getOpenAI();
    const response = await openai.chat.completions.create({
      model: "openai/gpt-4o-mini",
      messages: [{ role: "user", content: prompt }],
      response_format: { type: "json_object" },
      temperature: 0.3,
    });

    const raw = response.choices[0].message.content;
    const parsed = JSON.parse(raw);
    const subject = (parsed.subject || "").trim();
    const body = (parsed.body || "").trim();

    const reply = subject
      ? `Subject: ${subject}\n\n${body}`
      : body || raw;

    res.json({ reply });
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: "Something went wrong" });
  }
});

module.exports = router;
