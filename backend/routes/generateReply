const express = require("express");
const router = express.Router();
const OpenAI = require("openai");

function getOpenAI() {
  return new OpenAI({
    apiKey: process.env.OPENAI_API_KEY,
    baseURL: "https://openrouter.ai/api/v1",
  });
}

/** true = I committed; false = someone else committed to me */
function parseIsMine(value) {
  if (value === true || value === "true") return true;
  if (value === false || value === "false") return false;
  return false;
}

router.post("/", async (req, res) => {
  const { task, deadline, isMine: isMineRaw } = req.body;
  const isMine = parseIsMine(isMineRaw);

  if (task === undefined || task === null || String(task).trim() === "") {
    return res.status(400).json({ error: "task is required" });
  }

  const deadlineMs =
    deadline !== undefined &&
    deadline !== null &&
    String(deadline).trim() !== "" &&
    !Number.isNaN(Number(deadline))
      ? Number(deadline)
      : null;

  const nowMs = Date.now();
  // True only after the instant has passed (no apology before this)
  const missedDeadline =
    deadlineMs !== null && nowMs > deadlineMs;

  const deadlineIso =
    deadlineMs !== null ? new Date(deadlineMs).toISOString() : "unspecified";
  const nowIso = new Date().toISOString();

  const scenarioKey = `${isMine ? "mine" : "theirs"}_${missedDeadline ? "late" : "on_time_or_future"}`;

  const instructionsByScenario = {
    mine_late: `
The writer promised to do the task below and the deadline (see ISO time below) is ALREADY PAST relative to "right now".
Write a short apology / recommit email (2–4 sentences): acknowledge being late, restate the task, propose when you'll deliver.
When you mention time, use the EXACT deadline clock time from the ISO string (do not round 4:30 to 4:00).
Do NOT use placeholders like [Name]. No fake names.
`,
    mine_on_time_or_future: `
The writer promised to do the task below but the deadline is STILL IN THE FUTURE (or is now) relative to "right now" — they have NOT missed it.
Write a short professional email (2–4 sentences): e.g. quick update that you're on track, or confirm timing — NOT an apology for missing the deadline.
Do NOT say "sorry for missing the deadline" or imply the deadline passed.
If you mention the due time, copy it from the deadline ISO exactly (preserve :30, etc.).
Do NOT use placeholders like [Name]. No fake names.
`,
    theirs_late: `
The recipient of your email made the commitment below; the deadline ISO is already past relative to "right now".
Write a short polite follow-up (2–4 sentences) checking in on their overdue commitment. Not aggressive.
If you reference the due time, use the exact time from the deadline ISO (do not round).
Do NOT use placeholders like [Name]. No fake names.
`,
    theirs_on_time_or_future: `
The recipient made the commitment below; the deadline is STILL IN THE FUTURE relative to "right now" — they are NOT late yet.
Write a short polite check-in or reminder (2–4 sentences). Do NOT accuse them of missing the deadline or say they're late.
Do NOT apologize on your own behalf for their task.
If you mention the due time, use the exact time from the deadline ISO (preserve minutes).
Do NOT use placeholders like [Name]. No fake names.
`,
  };

  const branchInstructions =
    instructionsByScenario[scenarioKey] || instructionsByScenario.theirs_on_time_or_future;

  const prompt = `
FACTS (obey these; do not contradict):
- Right now (UTC): ${nowIso}
- Commitment deadline (UTC, exact instant): ${deadlineIso}
- missedDeadline (computed): ${missedDeadline ? "YES — deadline is in the past" : "NO — deadline is now or in the future"}

${branchInstructions}

Commitment (task summary): ${String(task).trim()}

Respond with ONLY valid JSON in this exact shape:
{"subject":"...","body":"..."}
subject = email subject line (no "Subject:" prefix).
body = email body only, plain text, use \\n for line breaks between paragraphs if needed.
`;

  try {
    const openai = getOpenAI();
    const response = await openai.chat.completions.create({
      model: "openai/gpt-4o-mini",
      messages: [{ role: "user", content: prompt }],
      response_format: { type: "json_object" },
      temperature: 0.3,
    });

    const raw = response.choices[0].message.content;
    const parsed = JSON.parse(raw);
    const subject = (parsed.subject || "").trim();
    const body = (parsed.body || "").trim();

    const reply = subject
      ? `Subject: ${subject}\n\n${body}`
      : body || raw;

    res.json({ reply });
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: "Something went wrong" });
  }
});

module.exports = router;
